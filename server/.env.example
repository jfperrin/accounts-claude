MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/account-claude?retryWrites=true
PORT=3001
CLIENT_URL=http://localhost:5173

# Google OAuth — optionnel, le bouton Google n'apparaît pas si absent
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic — budget analysis feature
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
MOCK_ANTHROPIC=
