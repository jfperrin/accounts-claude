{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/filter-verbose-bash.js" }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read(~/.claude/**)",
      "Read(//tmp/**)",
      "Bash(yarn *)",
      "Bash(node *)",
      "Bash(npx vitest *)",
      "Bash(docker compose *)",
      "Bash(git *)"
    ],
    "deny": [
      "Read(//lib/**)",
      "Edit(//lib/**)",
      "Read(~/**)",
      "Edit(~/**)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(chmod 777 *)",
      "Bash(chown *)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(> /dev/*)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)",
      "Bash(kill -9 *)",
      "Bash(killall *)",
      "Bash(pkill *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(halt *)",
      "Bash(poweroff *)",
      "Bash(passwd *)",
      "Bash(useradd *)",
      "Bash(userdel *)",
      "Bash(usermod *)"
    ]
  }
}
